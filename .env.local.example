# Local-first defaults — copy to .env.local and fill in your OpenRouter key.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Optional: shown in OpenRouter dashboard so you can identify spend
OPENROUTER_APP_TITLE=Job Search Copilot

# Database — local SQLite. For Neon Postgres deploy, replace with the Neon URL
# and change `provider` in prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# Adzuna — free job-search API. Register at https://developer.adzuna.com/ and
# paste your app id + key here. Without these, the Adzuna source is disabled
# (Greenhouse and Lever sources still work without any keys).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Resend — daily digest email provider (https://resend.com, free tier 3000/mo).
# Without RESEND_API_KEY the digest feature is silently disabled.
# RESEND_FROM_EMAIL defaults to onboarding@resend.dev (Resend's sandbox sender
# that only delivers to your own registered email — fine for personal use).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Gmail sync — OAuth credentials from https://console.cloud.google.com
# Create a project → enable Gmail API → OAuth consent screen → Credentials →
# Web application client → add http://localhost:3000/api/gmail/callback as a
# redirect URI. Without these, Gmail sync is silently disabled.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback
